# Frontend Environment Configuration
# Vercel Deployment Instructions:
# When deploying to Vercel, go to the project Settings -> Environment Variables.
# Add the following variable and set its value to your deployed Render backend URL WITH the /api suffix.
# Ensure you do NOT include a trailing slash (e.g., https://your-backend.onrender.com/api).

VITE_API_BASE_URL=http://localhost:8080/api
