{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix frontend/shop install",
  "buildCommand": "npm --prefix frontend/shop run build",
  "outputDirectory": "frontend/shop/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}